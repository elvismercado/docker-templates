TZ=Europe/London

CONTAINER_NAME=cloudflared
IMAGE_VERSION=latest

TUNNEL_TOKEN=

# Uncomment to enable Prometheus metrics + /ready endpoint
# /ready  — 200 when tunnel is connected, 503 otherwise (use with Uptime Kuma, etc.)
# /metrics — Prometheus-format metrics (scrape with Prometheus/Grafana)
# TUNNEL_METRICS=0.0.0.0:2000
# METRICS_PORT=2000

SUBNET=10.42.0.0/24

WATCHTOWER_ENABLE=false