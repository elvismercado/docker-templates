TZ=Europe/London

UID=99
GID=100
UMASK=022

CONTAINER_NAME=gitea
VOLUMES_BASE=/mnt/user/appdata
SUBNET=
HTTP_PORT=

# Gitea
IMAGE_VERSION=1

# PostgreSQL
POSTGRES_VERSION=14
DB_USER=gitea
DB_PASSWORD=gitea
DB_NAME=gitea

# Gitea Actions Runner
# Get the registration token from: Site Administration > Actions > Runners
# The runner will keep restarting until a valid token is provided
RUNNER_REGISTRATION_TOKEN=
RUNNER_VERSION=latest

# Docker socket for the Actions runner to spawn job containers
# Grants the runner near-root access to the host
DOCKER_SOCK=/var/run/docker.sock

# Runner job containers join this network (auto-syncs with CONTAINER_NAME)
# Edit runner-config.yaml only if you need additional runner options
# RUNNER_NETWORK is derived from CONTAINER_NAME — no need to set manually

WATCHTOWER_ENABLE=false
