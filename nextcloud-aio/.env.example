CONTAINER_NAME=nextcloud
VOLUMES_BASE=/mnt/user/appdata
SUBNET=

DOCKER_SOCK=

NEXTCLOUD_PORT=36149
NEXTCLOUD_DATADIR=/mnt/user/nextcloud
NEXTCLOUD_MOUNT=/mnt/disks
AIO_DISABLE_BACKUP_SECTION=false

# RAM tuning (upstream defaults in compose; override here for your server)
# Per-PHP-process memory limit (upstream default: 512M)
NEXTCLOUD_MEMORY_LIMIT=512M
# Fulltextsearch Elasticsearch JVM heap (upstream default: -Xms512M -Xmx512M)
# For 64GB RAM with 200k+ files, use: -Xms4096M -Xmx8192M
FULLTEXTSEARCH_JAVA_OPTIONS=-Xms512M -Xmx512M

# Hardware acceleration (set to true to enable)
NEXTCLOUD_ENABLE_DRI_DEVICE=false
NEXTCLOUD_ENABLE_NVIDIA_GPU=false