# =============================================================================
# setup.sh variables — used during setup only, not by the running containers
# =============================================================================

# Host volume root (Unraid: /mnt/user/appdata)
VOLUMES_BASE=/mnt/user/appdata

# Project namespace for directory paths
CONTAINER_NAME=coolify

# Docker network subnet for Coolify's own services (leave empty for default 10.42.0.0/24)
SUBNET=

# =============================================================================
# Initial admin account — eliminates the open registration security window
# =============================================================================
# Pre-creates the admin user on first boot so nobody can race the registration
# page. All 3 must be set together, or none — partial values are ignored.
#
# Password requirements: min 8 characters, must include uppercase, lowercase,
# number, and special character.

ROOT_USERNAME=
ROOT_USER_EMAIL=
ROOT_USER_PASSWORD=

# =============================================================================
# Coolify runtime variables — goes into /data/coolify/source/.env
# =============================================================================
# These are read by the official CDN compose files at container startup.
# setup.sh auto-generates secrets (DB_PASSWORD, REDIS_PASSWORD, PUSHER_APP_*)
# on first run. The variables below are the ones you may want to customize.

# Coolify UI port (default: 8000)
APP_PORT=8000

# WebSocket port — only change if 6001 conflicts with another service
# SOKETI_PORT=6001

# Timezone — set in docker-compose.custom.yml (CDN compose doesn't pass TZ)
TZ=Europe/London

# Auto-update — disabled by default; upgrades happen by re-running setup.sh
# Set to "true" to let Coolify auto-update itself (checks hourly, installs daily)
AUTOUPDATE=false